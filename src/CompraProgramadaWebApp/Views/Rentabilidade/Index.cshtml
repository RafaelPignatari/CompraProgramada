@model IEnumerable<CompraProgramada.Models.ClienteViewModel>

@{
    ViewData["Title"] = "Rentabilidade - Selecionar Cliente";
}

@section Styles {
    <link rel="stylesheet" href="~/css/rentabilidade.css" asp-append-version="true" />
}

<div class="rentabilidade-header">
    <h2 class="mb-0">Selecione um Cliente</h2>
    <p class="mb-0">Visualize a rentabilidade da carteira de investimentos</p>
</div>

<div class="mt-3">
    @if (Model != null && Model.Any())
    {
        <table class="table table-hover rentabilidade-table">
            <thead>
                <tr>
                    <th>Nome</th>
                    <th>CPF</th>
                    <th>Valor Mensal</th>
                    <th>Status</th>
                    <th>Ação</th>
                </tr>
            </thead>
            <tbody>
            @foreach(var cliente in Model)
            {
                <tr>
                    <td>@cliente.Nome</td>
                    <td>@cliente.CPF</td>
                    <td>@cliente.ValorMensal.ToString("C")</td>
                    <td>
                        @if (cliente.Ativo)
                        {
                            <span class="badge badge-itau-ativo">Ativo</span>
                        }
                        else
                        {
                            <span class="badge badge-itau-inativo">Inativo</span>
                        }
                    </td>
                    <td>
                        <a class="btn btn-itau btn-sm" asp-controller="Rentabilidade" asp-action="Detalhes" asp-route-id="@cliente.Id">Ver Rentabilidade</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-info">Nenhum cliente cadastrado no sistema.</div>
    }
</div>
